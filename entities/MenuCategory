{
  "name": "MenuCategory",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Category name e.g. Pizzas, Special Offers"
    },
    "description": {
      "type": "string"
    },
    "image_url": {
      "type": "string"
    },
    "icon_emoji": {
      "type": "string",
      "description": "Emoji icon e.g. \ud83c\udf55"
    },
    "sort_order": {
      "type": "number",
      "default": 0
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "badge": {
      "type": "string",
      "description": "Optional badge text e.g. New, Hot, 20% OFF"
    }
  },
  "required": [
    "name"
  ]
}