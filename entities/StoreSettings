{
  "name": "StoreSettings",
  "type": "object",
  "properties": {
    "store_name": {
      "type": "string"
    },
    "delivery_enabled": {
      "type": "boolean",
      "default": true
    },
    "pickup_enabled": {
      "type": "boolean",
      "default": true
    },
    "delivery_open_time_ms": {
      "type": "number",
      "description": "Delivery open time as milliseconds from midnight (e.g. 39600000 = 11:00 AM)"
    },
    "delivery_close_time_ms": {
      "type": "number",
      "description": "Delivery close time as milliseconds from midnight (e.g. 79200000 = 10:00 PM)"
    },
    "pickup_open_time_ms": {
      "type": "number",
      "description": "Pickup open time as milliseconds from midnight"
    },
    "pickup_close_time_ms": {
      "type": "number",
      "description": "Pickup close time as milliseconds from midnight"
    },
    "delivery_min_order": {
      "type": "number",
      "default": 10
    },
    "delivery_fee": {
      "type": "number",
      "default": 3.99
    },
    "delivery_free_threshold": {
      "type": "number",
      "default": 25
    },
    "estimated_delivery_mins": {
      "type": "number",
      "default": 35
    },
    "estimated_pickup_mins": {
      "type": "number",
      "default": 15
    }
  },
  "required": []
}